:root{
  /* ===== ORGANIC PREMIUM PALETTE ===== */
  --bg:#f6f8f4;              /* warm organic background */
  --panel:#ffffff;           /* clean card white */
  --text:#1f2a1f;            /* deep natural text */
  --muted:#6f7c6f;           /* soft muted green */

  --primary:#1f5f3a;         /* forest green (main brand) */
  --accent:#3e8f5a;          /* fresh leaf green */
  --premium:#c7a44b;         /* soft export gold (minimal use) */

  --border:rgba(31,95,58,.12);
  --shadow:0 18px 45px rgba(31,95,58,.08);

  --max:1120px;
  --radius:18px;
}

*{box-sizing:border-box}
html,body{margin:0;padding:0}

body{
  font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  color:var(--text);
  background:linear-gradient(180deg,#f9fbf7 0%,var(--bg) 100%);
  line-height:1.55;
}

a{color:inherit;text-decoration:none}
.container{max-width:var(--max);margin:0 auto;padding:0 18px}

/* ===== HEADER ===== */
.site-header{
  position:sticky;
  top:0;
  z-index:50;
  backdrop-filter:blur(10px);
  background:rgba(255,255,255,.85);
  border-bottom:1px solid var(--border);
}

.header-inner{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:12px 0;
  gap:14px;
}

.brand{
  display:flex;
  align-items:baseline;
  gap:10px;
  letter-spacing:.08em;
}

.brand-mark{
  font-weight:800;
  font-size:18px;
  color:var(--primary);
}

.brand-sub{
  font-weight:700;
  font-size:12px;
  color:var(--muted);
}

.nav{
  display:flex;
  gap:12px;
  align-items:center;
  flex-wrap:wrap;
  justify-content:flex-end;
}

.nav a{
  padding:10px 10px;
  color:var(--muted);
  border-radius:12px;
  transition:all .2s ease;
}

.nav a:hover{
  background:rgba(31,95,58,.08);
  color:var(--primary);
}

.btn{
  background:linear-gradient(135deg,var(--primary) 0%,var(--accent) 100%);
  color:#ffffff!important;
  font-weight:800;
  border-radius:14px;
  padding:10px 16px!important;
  box-shadow:0 10px 24px rgba(31,95,58,.25);
  transition:all .25s ease;
}

.btn:hover{
  transform:translateY(-1px);
  box-shadow:0 16px 34px rgba(31,95,58,.35);
}

/* Mobile header */
@media (max-width: 640px){
  .header-inner{padding:8px 0}
  .nav{gap:8px}
  .nav a{padding:8px 8px;font-size:13px}
}

/* ===== HERO ===== */
.hero{padding:42px 0 22px}

.hero-grid{
  display:grid;
  grid-template-columns:1.2fr .8fr;
  gap:22px;
  align-items:stretch;
}

@media(max-width:920px){
  .hero{padding:28px 0 18px}
  .hero-grid{grid-template-columns:1fr}
}

.card{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  box-shadow:var(--shadow);
}

.card.pad{padding:22px}

@media(max-width:540px){
  .card.pad{padding:18px}
}

.kicker{
  color:var(--primary);
  font-weight:800;
  letter-spacing:.12em;
  font-size:12px;
}

h1{
  margin:10px 0 12px;
  font-size:42px;
  line-height:1.08;
}

@media(max-width:540px){
  h1{font-size:32px;line-height:1.12}
}

.lead{color:var(--muted);font-size:16px;margin:0 0 16px}

.actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:16px}

.actions .ghost{
  background:transparent;
  border:1px solid rgba(31,95,58,.24);
  color:var(--primary);
  padding:10px 14px;
  border-radius:14px;
  font-weight:800;
  transition:all .2s ease;
}

.actions .ghost:hover{background:rgba(31,95,58,.08)}

/* ===== MEDIA CARDS ===== */
.media{position:relative;min-height:360px}

@media(max-width:920px){.media{min-height:320px}}
@media(max-width:540px){.media{min-height:260px}}

.media img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  filter:saturate(1.05) contrast(1.03);
}

.media .overlay{
  position:absolute;
  inset:0;
  background:linear-gradient(
    180deg,
    rgba(0,0,0,.08) 0%,
    rgba(0,0,0,.55) 70%,
    rgba(0,0,0,.75) 100%
  );
}

.media .label{
  position:absolute;
  left:18px;
  bottom:16px;
  right:18px;
}

.media .label strong{
  display:block;
  font-size:14px;
  letter-spacing:.08em;
  color:#fff;
}

.media .label span{
  display:block;
  color:rgba(255,255,255,.80);
  font-size:13px;
  margin-top:4px;
}

/* ===== SECTIONS ===== */
.section{padding:34px 0}

.section h2{
  margin:0 0 12px;
  font-size:26px;
  color:var(--primary);
}

.section p{color:var(--muted);margin:0 0 12px}

.grid3{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}

@media(max-width:920px){.grid3{grid-template-columns:1fr}}

.tile{padding:18px}

.tile h3{
  margin:4px 0 6px;
  font-size:16px;
  color:var(--text);
}

.tile p{margin:0;color:var(--muted);font-size:14px}

hr.sep{
  border:0;
  height:1px;
  background:rgba(31,95,58,.12);
  margin:26px 0;
}

/* ===== PAGE HERO ===== */
.page-hero{padding:36px 0 10px}

.breadcrumb{color:var(--muted);font-size:13px}

.page-title{
  margin:10px 0 10px;
  font-size:34px;
  line-height:1.12;
  color:var(--primary);
}

.page-sub{color:var(--muted);margin:0 0 18px}

/* ===== CARDS GRID ===== */
.cards{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:16px;
}

@media(max-width:920px){.cards{grid-template-columns:1fr}}

/* ===== VARIETIES ===== */
.variety{
  display:grid;
  grid-template-columns:190px 1fr;
  gap:14px;
  padding:16px;
}

@media(max-width:640px){.variety{grid-template-columns:1fr}}

.variety img{
  width:100%;
  height:160px;
  object-fit:cover;
  border-radius:14px;
  border:1px solid var(--border);
  background:#eef3ec;
}

.badge{
  display:inline-flex;
  gap:8px;
  align-items:center;
  padding:6px 10px;
  border-radius:999px;
  background:rgba(31,95,58,.06);
  border:1px solid rgba(31,95,58,.12);
  color:var(--muted);
  font-size:12px;
}

.meta{display:flex;gap:10px;flex-wrap:wrap;margin:8px 0 10px}

.kv{margin:0;color:var(--muted);font-size:13px}
.kv b{color:var(--text);font-weight:800}

.small{font-size:13px;color:var(--muted)}

/* ===== DETAILS ===== */
details{
  border:1px solid rgba(31,95,58,.14);
  border-radius:14px;
  padding:12px 14px;
  background:rgba(31,95,58,.03);
}

details summary{
  cursor:pointer;
  font-weight:800;
  color:var(--primary);
}

details p{margin:10px 0 0;color:var(--muted);font-size:14px}

/* ===== FOOTER ===== */
.site-footer{
  padding:34px 0;
  border-top:1px solid rgba(31,95,58,.14);
  color:var(--muted);
  background:linear-gradient(180deg,#f6f8f4 0%, #eef3ec 100%);
}

.footer-grid{
  display:grid;
  grid-template-columns:1.2fr .8fr;
  gap:18px;
}

@media(max-width:920px){.footer-grid{grid-template-columns:1fr}}

.notice{
  font-size:12px;
  color:rgba(31,42,31,.60);
  margin-top:12px;
}
